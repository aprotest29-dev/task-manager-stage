# ───────────────────────────────────────────
# .gitignore — Task Manager
# ───────────────────────────────────────────

# Dépendances Node.js
node_modules/
.pnpm-store/

# Builds et distributions
dist/
build/
.output/
out/

# Variables d'environnement (JAMAIS versionner les secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Système d'exploitation
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Éditeurs et IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo

# Cache
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# Tests
coverage/
.nyc_output/

# Replit (fichiers internes de la plateforme)
.replit
replit.nix
.local/

# Fichiers temporaires
tmp/
temp/
*.tmp
*.temp
